# ─── Supabase ───────────────────────────────────────────────────────────────
# Get these from your Supabase project dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── AI / 9router (OpenAI-compatible) ────────────────────────────────────────
# Your existing 9router API key (works with instructor + openai client)
OPENAI_API_KEY=your-9router-api-key
OPENAI_BASE_URL=https://api.9router.com/v1

# ─── Model Config ─────────────────────────────────────────────────────────────
# 9router is OpenAI-compatible, so standard model names work
AI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ─── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development  # development | staging | production
DEBUG=true

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Optional: Sentry DSN for error tracking ──────────────────────────────────
# SENTRY_DSN=https://your-dsn@sentry.io/project

# ─── Optional: Resend API for daily digest emails ──────────────────────────────
# RESEND_API_KEY=re_your_key_here
# DIGEST_EMAIL_FROM=noreply@recall.app